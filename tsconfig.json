{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
